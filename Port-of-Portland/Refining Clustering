    3: "Special Excavation / Soil Handling",
    4: "Storm Sewer Piping",
    5: "Curb, Concrete, & Backfill",
    6: "Grade & Surface Adjustment",
    7: "Mobilization & Demobilization",
    8: "Signage & Electrical Equipment",
    9: "Electrical Base & Transformer Install",
    10: "Inlet & Trench Protection",
    11: "Manhole & Catch Basin Adjustment",
    12: "Traffic Control (General)",
    13: "Asphalt Removal & Replacement",
    14: "Sweeping & Trench Treatment",
    15: "Asphalt Surface Course",
    16: "General Demolition (Electrical)",
    17: "Electrical Conduit & Wire",
    18: "PVC Pipe (Encased)",
    19: "Utility Escort / Electrical Install",
    20: "Geotextile & Fabric Separation",
    21: "Panel & Deck Repair",
    22: "Trench Marking & Reflectors",
    23: "Asphalt Cold Milling"
}

df_with_clusters["Cluster_Group_Name"] = (
    df_with_clusters["Cluster"]
    .map(material_cluster_labels)
    .fillna("Unclustered")
)

#  11. SAVE FIRST ROUND OUTPUTS 

df_with_clusters.to_csv(f"clustered_full_dataset_{num_clusters}.csv", index=False)

# Extract top 5 keywords per cluster for cluster definition output
def get_top_keywords(model, feature_names, top_n=5):
    
    Extract the top N keywords for each cluster based on centroid weights.
    Higher centroid weights indicate terms most representative of that cluster.
    
    keywords = {}
    for i in range(model.n_clusters):
        center_weights = model.cluster_centers_[i]
        top_indices = center_weights.argsort()[::-1][:top_n]
        keywords[i] = [feature_names[ind] for ind in top_indices]
    return keywords

feature_names = vectorizer.get_feature_names_out()
top_keywords = get_top_keywords(kmeans, feature_names, top_n=5)
cluster_sizes = df_with_clusters['Cluster'].value_counts(dropna=True).to_dict()

cluster_definitions = pd.DataFrame([
    {
        "Cluster": k,
        "ClusterLabel": material_cluster_labels.get(k, "Unlabeled"),
        "TopKeywords": ", ".join(top_keywords[k]),
        "ClusterSize": cluster_sizes.get(k, 0)
    }
    for k in range(kmeans.n_clusters)
])

cluster_definitions.to_csv(f"cluster_definitions_{num_clusters}.csv", index=False)
print(f"\n First round clustering saved: {num_clusters} clusters")

# 12. RECLUSTER CLUSTER 0 — SITE UTILITIES (TOO BROAD) 
# Isolate Cluster 0 for subclustering

# Cluster 0 (Site Utilities) was identified as too broad after reviewing
# its top keywords — it contained a highly diverse mix of utility work types
# that needed finer granularity for meaningful contractor price comparison.

# Rather than re-running the full clustering with more clusters (which would
# fragment the well-defined clusters), we selectively recluster only
# Cluster 0 into subgroups — a targeted refinement approach.

# Custom stopwords are added for this subcluster pass to suppress domain
# terms that dominate Cluster 0 specifically but don't differentiate
# between the subgroups we're trying to identify.

print("\nReclustering Cluster 0 (Site Utilities) into subgroups...")

cluster_0_df = df_with_clusters[df_with_clusters["Cluster"] == 0].copy()
print(f"  Total rows in Cluster 0: {len(cluster_0_df):,}")
print(f"  Unique RowNumbers in Cluster 0: {cluster_0_df['RowNumber'].nunique():,}")

# Build custom stopword list for Cluster 0 subclustering
# These terms appear too frequently within Cluster 0 to differentiate subgroups
default_stopwords = set(stopwords.words('english'))
custom_terms = {
    "workhouse", "window", "yv", "electrical", "material", "structure",
    "unit", "area", "control", "controlled", "zone", "enclosure"
}
combined_stopwords = default_stopwords.union(custom_terms)

# Fit a new vectorizer on Cluster 0 descriptions only with custom stopwords
vectorizer_0 = TfidfVectorizer(
    stop_words=list(combined_stopwords),
    max_df=0.85,
    min_df=2
)
X0 = vectorizer_0.fit_transform(cluster_0_df["Cleaned_Description"])

# Silhouette scoring to find optimal subcluster count within Cluster 0
sil_scores_0 = []
K_range_0 = range(6, 15)

for k in K_range_0:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X0)
    score = silhouette_score(X0, labels)
    sil_scores_0.append((k, score))
    print(f"  Subclusters: {k} → Silhouette Score: {score:.4f}")

best_sub_k = max(sil_scores_0, key=lambda x: x[1])
print(f"\n Optimal subcluster count: {best_sub_k[0]} (Score = {best_sub_k[1]:.4f})")

# Final subclustering of Cluster 0
num_subclusters = best_sub_k[0]
kmeans_0 = KMeans(n_clusters=num_subclusters, random_state=42, n_init=10)
cluster_0_labels = kmeans_0.fit_predict(X0)

# Assign zero-padded subgroup labels for hierarchical readability
# Format: "0.00", "0.01", "0.02" — clearly shows parent cluster (0) and subgroup
cluster_0_df["Cluster_0_Subgroup"] = [f"0.{i:02d}" for i in cluster_0_labels]

# Merge subgroups back into main dataset
cluster_0_merge = cluster_0_df[["RowNumber", "Cluster_0_Subgroup"]].drop_duplicates()

print(f"\nMerging Cluster 0 subgroups back to full dataset...")
print(f"  Before merge: {len(df_with_clusters):,} rows")

df_with_clusters = df_with_clusters.merge(
    cluster_0_merge,
    on="RowNumber",
    how="left"
)

print(f"  After merge: {len(df_with_clusters):,} rows")

# 13. SUBCLUSTER DEFINITIONS FOR CLUSTER 0 

def get_top_keywords_subgroup(model, feature_names, top_n=5):
    #Extract top keywords for each subcluster using zero-padded label format.
    keywords = {}
    for i in range(model.n_clusters):
        center_weights = model.cluster_centers_[i]
        top_indices = center_weights.argsort()[::-1][:top_n]
        keywords[f"0.{i:02d}"] = [feature_names[ind] for ind in top_indices]
    return keywords

feature_names_0 = vectorizer_0.get_feature_names_out()
subgroup_keywords = get_top_keywords_subgroup(kmeans_0, feature_names_0, top_n=5)

subgroup_sizes = (
    cluster_0_df["Cluster_0_Subgroup"]
    .astype(str)
    .value_counts()
    .to_dict()
)

subgroup_definitions = pd.DataFrame([
    {
        "Cluster_0_Subgroup": k,
        "TopKeywords": ", ".join(subgroup_keywords[k]),
        "SubgroupSize": subgroup_sizes.get(k, 0)
    }
    for k in sorted(subgroup_keywords.keys())
])

# Drop cleaned description column — no longer needed in final output
df_with_clusters = df_with_clusters.drop(columns=["Cleaned_Description"])

