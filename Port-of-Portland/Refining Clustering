    "0.12": f"{cluster_0_base_label} - General Utility Material (Needs SME)",
    "0.13": f"{cluster_0_base_label} - Bollard Installation & Deck Embeds"
}

# Map subcluster labels and merge back to full dataset
cluster_0_df["Subcluster_Full_Label"] = cluster_0_df["Cluster_0_Subgroup"].map(subcluster_0_labels)

cluster_0_merge = cluster_0_df[
    ["RowNumber", "Cluster_0_Subgroup", "Subcluster_Full_Label"]
].drop_duplicates()

df_with_clusters = df_with_clusters.merge(
    cluster_0_merge,
    on="RowNumber",
    how="left"
)

# Save subgroup definitions
subgroup_definitions.to_csv(f"cluster_0_subgroup_definitions_{num_subclusters}.csv", index=False)

# 15. BUILD FINAL UNIFIED CLUSTER LABEL 
                                  
def get_cluster_full_label(row):
    
    Assign a final human-readable label to every row in the dataset.

    Priority logic:
        1. If a Cluster 0 subcluster label exists — use it (most specific)
        2. If a main cluster label exists — use it
        3. Otherwise — mark as Unclustered

    This ensures every record has the most granular label available,
    with Cluster 0 items getting their refined subcluster labels
    rather than the broad "Site Utilities" parent label.
    
    if pd.notnull(row["Subcluster_Full_Label"]):
        return row["Subcluster_Full_Label"]
    elif pd.notnull(row["Cluster"]):
        return f'{int(row["Cluster"])} - {material_cluster_labels.get(int(row["Cluster"]), "Other")}'
    else:
        return "Unclustered"

df_with_clusters["Cluster_Full_Label"] = df_with_clusters.apply(get_cluster_full_label, axis=1)

# 16. EXPORT FINAL LABELED DATASET 

df_with_clusters.to_csv("clustered_full_output.csv", index=False)

print(f"\n Pipeline complete")
print(f"   Final labeled dataset saved to: clustered_full_output.csv")
print(f"   Subgroup definitions saved to: cluster_0_subgroup_definitions_{num_subclusters}.csv")
print(f"   Total records: {len(df_with_clusters):,}")
print(f"   Unique cluster labels: {df_with_clusters['Cluster_Full_Label'].nunique()}")
