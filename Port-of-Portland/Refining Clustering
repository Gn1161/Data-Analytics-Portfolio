# The hierarchical format "Site Utilities - [Subtype]" preserves the
# parent cluster context while providing actionable subgroup specificity.

cluster_0_base_label = "Site Utilities"

subcluster_0_labels = {
    "0.00": f"{cluster_0_base_label} - Charging Stations / Utility Core Work",
    "0.01": f"{cluster_0_base_label} - Site Clearing & Seeding",
    "0.02": f"{cluster_0_base_label} - Fencing, Gates & Signage",
    "0.03": f"{cluster_0_base_label} - Buried Pipe & Material Removal",
    "0.04": f"{cluster_0_base_label} - Electrical Circuitry Install (Enclosed)",
    "0.05": f"{cluster_0_base_label} - Steel Plates, Anchors & Cable Retrieval",
    "0.06": f"{cluster_0_base_label} - Manhole Connections / Water Utility",
    "0.07": f"{cluster_0_base_label} - Erosion Control (Wattle) & Misc",
    "0.08": f"{cluster_0_base_label} - Adhesives / Compounds / Misc Deck",
    "0.09": f"{cluster_0_base_label} - Grounding & Rods (Counterpoise)",
    "0.10": f"{cluster_0_base_label} - Conduit & Data Charger Installs",
